{
  /*
   * CONFIGURAĂ‡ĂƒO BASE DO TYPESCRIPT â€” COMPARTILHADA POR TODOS OS WORKSPACES
   *
   * Cada workspace (apps/api, apps/web, packages/types) herda este arquivo via
   * "extends": "../../tsconfig.base.json" e sobrescreve apenas o necessĂ¡rio,
   * como `outDir`, `rootDir`, `include` e configuraĂ§Ăµes especĂ­ficas de framework.
   *
   * Objetivo: garantir consistĂªncia de compilaĂ§Ă£o e regras estritas em todo
   * o monorepo sem repetir configuraĂ§Ă£o.
   */
  "compilerOptions": {

    /*
     * TARGET E MĂ“DULOS
     *
     * ES2022 oferece suporte a `await` no nĂ­vel do mĂ³dulo (top-level await),
     * class fields nativas e outras features modernas que tanto o Node 20
     * quanto os browsers modernos suportam nativamente.
     *
     * "bundler" como moduleResolution delega a resoluĂ§Ă£o de imports ao bundler
     * (Vite, Next.js, tsx) e permite path aliases sem configuraĂ§Ă£o extra.
     */
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],

    /*
     * RIGOR DE TIPAGEM
     *
     * `strict: true` habilita um conjunto de verificaĂ§Ăµes que previnem bugs
     * silenciosos: strictNullChecks, noImplicitAny, strictFunctionTypes, etc.
     *
     * `noUncheckedIndexedAccess` Ă© especialmente importante para arrays e
     * records: sem ele, `arr[0]` tem tipo `T` mesmo que o array possa estar
     * vazio; com ele, o tipo fica `T | undefined`, forĂ§ando checagem explĂ­cita.
     *
     * `exactOptionalPropertyTypes` impede que propriedades opcionais recebam
     * `undefined` explicitamente â€” distingue `{ a?: string }` de `{ a: string | undefined }`.
     */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /*
     * INTEROPERABILIDADE COM CommonJS
     *
     * Muitas dependĂªncias do ecossistema Node.js ainda publicam em CJS.
     * `esModuleInterop` permite usar `import X from 'modulo-cjs'` sem erros,
     * em vez de `import * as X from 'modulo-cjs'`.
     */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    /*
     * DECORATORS
     *
     * Habilitado para compatibilidade com bibliotecas que utilizam decorators
     * (ex: algumas integraĂ§Ăµes do Fastify e futuros ORM adapters).
     */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /*
     * RESOLUĂ‡ĂƒO DE PATHS
     *
     * `baseUrl` Ă© definido em "." para que os workspaces filhos possam
     * configurar aliases relativos a si mesmos (ex: "@/*": ["./src/*"]).
     */
    "baseUrl": ".",

    /*
     * VERIFICAĂ‡ĂƒO SEM EMISSĂƒO
     *
     * `skipLibCheck` evita verificaĂ§Ă£o de tipos em arquivos .d.ts de
     * dependĂªncias externas â€” acelera o typecheck sem perder seguranĂ§a
     * no cĂ³digo prĂ³prio do projeto.
     */
    "skipLibCheck": true,

    /*
     * ISOLAMENTO DE MĂ“DULOS
     *
     * NecessĂ¡rio quando se usa um transpilador por arquivo (tsx, esbuild, swc),
