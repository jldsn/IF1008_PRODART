# ─── BANCO DE DADOS ───────────────────────────────────────────────────────────
# URL de conexão usada pelo Prisma. Formato:
#   postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
#
# Em desenvolvimento local, o padrão é:
#   postgresql://postgres:postgres@localhost:5432/prodarte?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prodarte?schema=public"

# ─── AUTENTICAÇÃO JWT ─────────────────────────────────────────────────────────
# Chave secreta usada para assinar e verificar os tokens JWT dos gestores.
# IMPORTANTE: em produção, gere um valor aleatório longo (mínimo 32 caracteres).
# Exemplo: openssl rand -base64 32
JWT_SECRET="troque-este-valor-em-producao"

# Tempo de expiração do token de acesso. Formatos aceitos: "7d", "24h", "3600s"
JWT_EXPIRATION="7d"

# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
# Porta onde a API vai escutar. O padrão 3001 evita conflito com o Next.js (3000).
PORT=3001

# Host onde a API vai escutar. Em Docker, use "0.0.0.0".
HOST="127.0.0.1"

# Ambiente de execução. Valores válidos: "development" | "production" | "test"
NODE_ENV="development"

# ─── WHATSAPP API ─────────────────────────────────────────────────────────────
# Token de acesso da API do WhatsApp Business (Meta).
# Deixe em branco em desenvolvimento — a integração será mockada.
WHATSAPP_TOKEN=""

# ID do número de telefone registrado na plataforma Meta Business.
WHATSAPP_PHONE_ID=""

# ─── UPLOAD DE ARQUIVOS ───────────────────────────────────────────────────────
# Tamanho máximo permitido por arquivo em bytes (padrão: 5MB = 5242880).
# Limitação definida no RNF03 do documento de requisitos.
UPLOAD_MAX_BYTES=5242880
