// ─────────────────────────────────────────────────────────────────────────────
// SCHEMA PRISMA — PRODARTE
//
// Este arquivo define todos os modelos, enums e relações do banco de dados.
// Após qualquer alteração aqui, execute:
//   npx prisma migrate dev --name <descricao>   → cria e aplica uma migration
//   npx prisma generate                         → regenera o Prisma Client
//
// Referências do domínio: ver documento de requisitos, seções 4 (US) e 6 (RF).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // A URL é lida da variável DATABASE_URL no arquivo .env da API.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

// Segmentos de atuação dos artesãos cadastrados no PRODARTE.
// Mapeado diretamente às opções do formulário externo da EMPREL (RF01/RNF01).
enum Segmento {
  ARTESANATO
  GASTRONOMIA
}

// Status do processo de curadoria técnica realizado pelo gestor.
// Referência: US03, RF04, RF05.
enum StatusCuradoria {
  EM_ANALISE  // estado inicial ao receber uma nova inscrição
  APROVADO    // artesão apto a participar de feiras
  REJEITADO   // documentação com pendência (exige justificativa obrigatória)
}

// Tipos de documento que podem ser anexados ao cadastro de um artesão.
// Limitados a PDF, JPG e PNG conforme RNF03 (segurança no upload de arquivos).
enum TipoDocumento {
  RG
  CPF_DOC
  COMPROVANTE_RESIDENCIA
  PORTFOLIO              // fotos dos produtos artesanais para curadoria técnica
  MEI                   // comprovante de Microempreendedor Individual
  OUTRO
}

// Status de uma alocação de artesão em feira.
// Referência: US07, RF09.
enum StatusAlocacao {
  ALOCADO    // artesão confirmado para a feira
  CANCELADO  // vaga liberada após cancelamento (a vaga é devolvida ao limite)
}

// Tipos de mensagem enviadas via WhatsApp pelo sistema.
// Referência: US04 (massa/individual), US08 (convocação), RF06, RF07.
enum TipoMensagem {
  REJEICAO    // notificação automática ao artesão quando documentação é rejeitada
  CONVOCACAO  // notificação automática com detalhes da feira ao artesão alocado
  MASSA       // disparo manual em massa para lista filtrada de artesãos
  INDIVIDUAL  // mensagem manual direcionada a um único artesão
}

// Status de entrega da mensagem enviada à API do WhatsApp.
enum StatusEnvio {
  PENDENTE  // na fila para envio
  ENVIADO   // confirmação de entrega pela API do WhatsApp
  FALHOU    // erro retornado pela API — registrado para reenvio manual
}

// ─── MODELOS ─────────────────────────────────────────────────────────────────

// Representa um gestor do PRODARTE com acesso ao backoffice.
// Referência: RF13 (autenticação), RNF04 (acesso a dados sensíveis), RNF05 (senhas).
model Gestor {
  id       String @id @default(cuid())
  email    String @unique
  // Senha armazenada como hash bcrypt — NUNCA armazenar texto puro.
  // A política de complexidade é validada na camada de rota (Zod + RNF05).
  senha    String
  nome     String

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  // Um gestor pode registrar múltiplas curadorias ao longo do tempo.
  curadorias Curadoria[]
  // Registro de todas as mensagens disparadas por este gestor.
  mensagens  Mensagem[]
}

// Representa um artesão cadastrado no PRODARTE.
// A origem dos dados é o formulário externo da EMPREL, sincronizado via RF01/RF06.
// O artesão NÃO tem acesso ao backoffice — é sempre um usuário passivo.
model Artesao {
  id String @id @default(cuid())

  // ── Dados pessoais ──────────────────────────────────────────────────────
  nome           String
  // CPF é o identificador único do artesão no programa.
  // Armazenado apenas como dígitos (sem formatação), ex: "12345678901".
  cpf            String   @unique
  rg             String?
  dataNascimento DateTime?
  // Telefone no formato internacional sem espaços, ex: "+55819XXXXXXXX".
  // É o canal principal de comunicação via WhatsApp.
  telefone       String
  email          String?

  // ── Endereço ────────────────────────────────────────────────────────────
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  uf          String?
  cep         String?

  // ── Dados do negócio ────────────────────────────────────────────────────
  nomeMarca        String?
  segmento         Segmento
  // Descrição detalhada dos produtos — usada na curadoria técnica.
  descricaoProduto String?

  // ── Formalização ────────────────────────────────────────────────────────
  possuiMEI Boolean @default(false)
  // CNPJ armazenado apenas se possuiMEI = true.
  cnpj      String?

  // ── Status e datas ──────────────────────────────────────────────────────
  // Status atual da curadoria. Começa em EM_ANALISE ao chegar pelo formulário.
  statusCuradoria StatusCuradoria @default(EM_ANALISE)
  dataInscricao   DateTime        @default(now())
  atualizadoEm    DateTime        @updatedAt

  // ── Relações ────────────────────────────────────────────────────────────
  documentos Documento[]
  // Histórico completo de todas as avaliações de curadoria deste artesão.
  curadorias Curadoria[]
  // Todas as alocações em feiras (passadas e futuras).
  alocacoes  Alocacao[]
  // Histórico de mensagens recebidas.
  mensagens  Mensagem[]
}

// Documento anexado ao cadastro de um artesão (portfólio, RG, comprovante, etc.).
// Upload restrito a PDF, JPG e PNG com limite de 5MB por arquivo (RNF03).
model Documento {
  id        String        @id @default(cuid())
  artesaoId String
  tipo      TipoDocumento
  // Caminho relativo no storage (ex: "documentos/artesao-id/rg.pdf").
  // O host base do storage é configurado via variável de ambiente.
  url       String
  // Tipo MIME validado no momento do upload para evitar injeção de arquivos.
  mimeType  String
  // Tamanho em bytes — usado para verificar o limite de 5MB (5.242.880 bytes).
  tamanhoBytes Int
  criadoEm  DateTime      @default(now())

  artesao Artesao @relation(fields: [artesaoId], references: [id], onDelete: Cascade)
}

// Registro de uma avaliação de curadoria feita por um gestor sobre um artesão.
// Cada mudança de status gera um novo registro — preservando o histórico completo.
// Referência: US03, RF04, RF05.
model Curadoria {
  id        String          @id @default(cuid())
  artesaoId String
  gestorId  String
  status    StatusCuradoria
  // Justificativa é obrigatória quando status = REJEITADO (CA03-02, RN do UC05).
  // A validação dessa regra ocorre na camada de rota com Zod.
  justificativa String?
  criadaEm      DateTime @default(now())

  artesao Artesao @relation(fields: [artesaoId], references: [id], onDelete: Cascade)
  gestor  Gestor  @relation(fields: [gestorId], references: [id])
}

// Representa um evento de feira gerenciado pelo PRODARTE.
// Referência: US05, US07, RF08, RF09.
model Feira {
  id    String @id @default(cuid())
  nome  String
  // Data e hora de início da feira. Não pode ser no passado (CA05-02).
  data  DateTime
  local String
  // Capacidade máxima de artesãos. Deve ser um inteiro positivo (CA05-03).
  limiteVagas Int
  // vagasRestantes é decrementado a cada nova Alocacao e incrementado
  // a cada cancelamento. Começa igual a limiteVagas.
  vagasRestantes Int

  criadaEm     DateTime @default(now())
  atualizadaEm DateTime @updatedAt

  alocacoes Alocacao[]
}

// Vincula um artesão aprovado a uma feira específica.
// Referência: US07 (alocar), US08 (notificar), RF09.
model Alocacao {
  id        String        @id @default(cuid())
  artesaoId String
  feiraId   String
  status    StatusAlocacao @default(ALOCADO)
  criadaEm  DateTime      @default(now())

  artesao Artesao @relation(fields: [artesaoId], references: [id], onDelete: Cascade)
  feira   Feira   @relation(fields: [feiraId], references: [id], onDelete: Cascade)

  // Impede que o mesmo artesão seja alocado duas vezes na mesma feira (CA07-03 implícito).
  @@unique([artesaoId, feiraId])
}

// Registro de todas as mensagens enviadas via WhatsApp pelo sistema.
// Mantém rastreabilidade completa conforme UC11 (regra de negócio: toda comunicação
// deve ser registrada no histórico do artesão).
model Mensagem {
  id        String       @id @default(cuid())
  // gestorId é nulo quando a mensagem é automática (ex: convocação após alocação).
  gestorId  String?
  artesaoId String
  conteudo  String
  tipo      TipoMensagem
  status    StatusEnvio  @default(PENDENTE)
  // Preenchido quando status muda para ENVIADO ou FALHOU.
  processadaEm DateTime?
  criadaEm     DateTime  @default(now())

  gestor  Gestor? @relation(fields: [gestorId], references: [id])
  artesao Artesao @relation(fields: [artesaoId], references: [id], onDelete: Cascade)
}
