{
  /*
   * Herda as opções base do monorepo e adiciona configurações
   * específicas para o ambiente Node.js da API.
   */
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /*
     * outDir: onde os arquivos .js compilados são gerados no build de produção.
     * Em desenvolvimento, o `tsx watch` transpila on-the-fly sem escrever em disco.
     */
    "outDir": "./dist",
    "rootDir": "./src",

    /*
     * paths: alias "@/*" mapeia para src/, permitindo imports absolutos
     * como `import { db } from '@/lib/prisma'` em vez de caminhos
     * relativos com múltiplos "../../../".
     */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "prisma/seed.ts"],
  "exclude": ["node_modules", "dist"]
}
