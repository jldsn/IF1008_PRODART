# ─── API ──────────────────────────────────────────────────────────────────────
# URL base da API Fastify. Usada nos rewrites do next.config.ts.
# Em desenvolvimento, a API roda em localhost:3001.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# URL usada apenas dentro do Docker Compose para o container web falar com a API.
INTERNAL_API_URL="http://api:3001"
